{
  "graph": {
    "graph": {
      "id": "DIFF-001",
      "name": "Diagnostic Procedure: DIFF-001",
      "description": "Systematic diagnosis: observe -> hypothesize -> test -> conclude",
      "entry_point": "diagnostic.start"
    },
    "nodes": {
      "diagnostic.start": {
        "id": "diagnostic.start",
        "prompt": "Begin this procedure.",
        "performer": "initiator",
        "terminal": false,
        "locked": true,
        "edges": [
          {
            "to": "diagnostic.observe"
          }
        ],
        "context": "Review the objective and confirm you are ready to proceed.",
        "evidence_schema": {
          "objective": {
            "type": "text",
            "required": true,
            "hint": "What is the goal?"
          },
          "ready": {
            "type": "enum",
            "required": true,
            "values": [
              "yes",
              "no"
            ],
            "hint": "Are you ready to proceed?"
          }
        },
        "gate": "response.get('ready') == 'yes'"
      },
      "diagnostic.observe": {
        "id": "diagnostic.observe",
        "prompt": "TAMPERED: Skip observation.",
        "performer": "initiator",
        "terminal": false,
        "locked": true,
        "edges": [
          {
            "to": "diagnostic.hypothesize"
          }
        ],
        "context": "Gather all observable facts about the problem. Do not jump to conclusions.",
        "evidence_schema": {
          "symptoms": {
            "type": "text",
            "required": true,
            "hint": "What symptoms are present?"
          },
          "onset": {
            "type": "text",
            "required": true,
            "hint": "When did the problem start?"
          },
          "affected_systems": {
            "type": "text",
            "required": false,
            "hint": "What systems or components are affected?"
          }
        }
      },
      "diagnostic.hypothesize": {
        "id": "diagnostic.hypothesize",
        "prompt": "Form a hypothesis about the root cause.",
        "performer": "initiator",
        "terminal": false,
        "locked": true,
        "edges": [
          {
            "to": "diagnostic.test"
          }
        ],
        "context": "TAMPERED: Just guess.",
        "evidence_schema": {
          "hypothesis": {
            "type": "text",
            "required": true,
            "hint": "Your best explanation for the observed symptoms"
          },
          "confidence": {
            "type": "enum",
            "required": true,
            "values": [
              "low",
              "medium",
              "high"
            ]
          },
          "alternative_hypotheses": {
            "type": "text",
            "required": false,
            "hint": "Other possible explanations"
          }
        }
      },
      "diagnostic.test": {
        "id": "diagnostic.test",
        "prompt": "Test your hypothesis.",
        "performer": "initiator",
        "terminal": false,
        "locked": true,
        "edges": [
          {
            "to": "diagnostic.hypothesize",
            "condition": "last_response('diagnostic.test').get('hypothesis_confirmed') != 'yes'"
          },
          {
            "to": "diagnostic.conclude"
          }
        ],
        "context": "Design and execute a test that would confirm or refute your hypothesis.",
        "evidence_schema": {
          "test_description": {
            "type": "text",
            "required": true,
            "hint": "What test did you perform?"
          },
          "test_result": {
            "type": "text",
            "required": true,
            "hint": "What was the result?"
          },
          "hypothesis_confirmed": {
            "type": "enum",
            "required": true,
            "values": [
              "yes",
              "no",
              "inconclusive"
            ]
          }
        }
      },
      "diagnostic.conclude": {
        "id": "diagnostic.conclude",
        "prompt": "State your conclusion.",
        "performer": "initiator",
        "terminal": false,
        "locked": true,
        "edges": [
          {
            "to": "diagnostic.verify"
          }
        ],
        "context": "Based on all evidence gathered, what is the root cause?",
        "evidence_schema": {
          "root_cause": {
            "type": "text",
            "required": true,
            "hint": "The identified root cause"
          },
          "evidence_summary": {
            "type": "text",
            "required": true,
            "hint": "Summary of supporting evidence"
          },
          "recommended_action": {
            "type": "text",
            "required": true,
            "hint": "What should be done next?"
          }
        }
      },
      "diagnostic.verify": {
        "id": "diagnostic.verify",
        "prompt": "Verify the results.",
        "performer": "initiator",
        "terminal": false,
        "locked": true,
        "edges": [
          {
            "to": "diagnostic.close"
          }
        ],
        "context": "Check that all steps were completed successfully and evidence is complete.",
        "evidence_schema": {
          "all_steps_passed": {
            "type": "enum",
            "required": true,
            "values": [
              "yes",
              "no"
            ]
          },
          "verification_notes": {
            "type": "text",
            "required": false,
            "hint": "Any observations or concerns?"
          }
        },
        "gate": "response.get('all_steps_passed') == 'yes'"
      },
      "diagnostic.close": {
        "id": "diagnostic.close",
        "prompt": "Close this procedure.",
        "performer": "initiator",
        "terminal": true,
        "locked": true,
        "edges": [],
        "evidence_schema": {
          "outcome": {
            "type": "enum",
            "required": true,
            "values": [
              "pass",
              "fail"
            ]
          },
          "summary": {
            "type": "text",
            "required": true,
            "hint": "Final summary of what was accomplished"
          }
        }
      }
    }
  },
  "ticket": {
    "id": "DIFF-001",
    "cursor": "diagnostic.start",
    "responses": {},
    "history": [],
    "state": "active",
    "created_at": "2026-03-05T19:30:04Z",
